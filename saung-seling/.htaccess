DirectoryIndex index.html
Options -Indexes

RewriteEngine On

# Redirect direct request for index.html or index to the folder root
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)/index(\.html)?\s [NC]
RewriteRule ^ %1/ [R=301,L]

# Redirect other direct requests for *.html to clean URL
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html\s [NC]
RewriteRule ^ %1 [R=301,L]

# Internally rewrite clean URLs to .html files if they exist
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*?)/?$ $1.html [L]
